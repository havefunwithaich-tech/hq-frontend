// hq-frontend/pages/index.js

import { GraphQLClient, gql } from 'graphql-request';

// WP_GRAPHQL_URLを環境変数から読み込む
const endpoint = process.env.WP_GRAPHQL_URL;
const graphQLClient = new GraphQLClient(endpoint);

// ----------------------------------------------------
// 1. 固定ページ取得用クエリ
// ----------------------------------------------------
const GET_PAGE = gql` 
  query GetHomePage {
    pageBy(uri: "HQ.havefunwithAIch/") { // 👈 WPで設定したURIに修正
      title
      content
      slug
    }
  }
`;

// ----------------------------------------------------
// 2. 将来の投稿リスト取得用クエリ (例として定義)
// ----------------------------------------------------
/*
const GET_POSTS_LIST = gql`
  query GetPostsList {
    posts(first: 5) { // 最新記事5件を取得
      nodes {
        title
        slug
      }
    }
  }
`;
*/


// サーバー側でビルド時に実行される関数 (SSG)
export async function getStaticProps() {
  try {
    const data = await graphQLClient.request(GET_PAGE);
    const data = await graphQLClient.request(GET_POSTS);

    return {
      props: {
        post: data.posts.nodes[0] || null,
      },
      // 1時間ごとにWPの更新をチェック (ISR: Incremental Static Regeneration)
      revalidate: 3600,
    };
} catch (error) {
    console.error("GraphQL Fetch Error:", error);

    // 💡 修正点: エラー時は null を返し、コンポーネントに制御を渡す
    return {
      props: {
        post: null 
      },
    };
  }
}

// Next.jsのコンポーネント
export default function HomePage({ post }) {
  if (!post) {
    return <div>No posts found. Check your WP backend.</div>;
  }

  // WPから取得したコンテンツをそのまま表示
  return (
    <div>
      <h1 style={{ textAlign: 'center' }}>{post.title}</h1>
      <div dangerouslySetInnerHTML={{ __html: post.content }} />
      <p style={{ textAlign: 'center', marginTop: '40px' }}>
        --- Content successfully fetched from WP Headless ---
      </p>
    </div>
  );
}
